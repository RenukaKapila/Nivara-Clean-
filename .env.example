# Optional public support link. Example: a Ko-fi, Buy Me a Coffee, GitHub Sponsors,
# Stripe Payment Link, or other hosted support page.
# Do not put secret payment keys in Vite environment variables.
VITE_SUPPORT_URL=

# Optional Vite base path for static hosting.
# Local development should stay "/".
# GitHub Pages project sites may need "/Nivara-clean/".
VITE_BASE_PATH=/

# Optional future Supabase public config. Leave blank for the local-first MVP.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
